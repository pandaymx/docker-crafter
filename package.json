{
  "version": "1.0.0",
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.72.0",
    "release-it": "^20.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "prepare": "husky",
    "release": "release-it"
  },
  "lint-staged": {
    "frontend/**/*.{js,ts,tsx,json}": [
      "bun --cwd frontend oxlint --deny-warnings",
      "bun --cwd frontend biome format --write"
    ],
    "*.go": [
      "gofmt -w"
    ]
  }
}

{
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.72.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "bun --bun oxlint"
    ],
    "frontend/**/*.{ts,tsx,js,jsx,mjs,cjs}": [
      "bunx --cwd frontend biome format --write"
    ],
    "*.go": [
      "gofmt -w"
    ]
  }
}
